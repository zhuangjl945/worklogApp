<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zjl.worklog.work.mapper.WorkStatusMapper">

    <resultMap id="WorkStatusMap" type="com.zjl.worklog.work.entity.WorkStatus">
        <id column="id" property="id"/>
        <result column="status_name" property="statusName"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="status" property="status"/>
    </resultMap>

    <select id="selectAllEnabled" resultMap="WorkStatusMap">
        SELECT id, status_name, sort_order, status
        FROM work_status
        WHERE status = 1
        ORDER BY sort_order ASC, id ASC
    </select>

</mapper>
