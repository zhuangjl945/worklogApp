server:
  port: 8080

# 生产环境数据库配置（使用环境变量）
# spring:
#   datasource:
#     url: jdbc:mysql://localhost:3306/work_log_system?useSSL=false&serverTimezone=Asia/Shanghai&characterEncoding=utf8
#     username: ${MYSQL_PROD_USER}
#     password: ${MYSQL_PROD_PASS}
#     driver-class-name: com.mysql.cj.jdbc.Driver

# 开发环境数据库配置
spring:
  datasource:
    url: jdbc:mysql://localhost:3306/work_log_system?useSSL=false&serverTimezone=Asia/Shanghai&characterEncoding=utf8
    username: root
    password: your_password_here  # 请修改为你的数据库密码
    driver-class-name: com.mysql.cj.jdbc.Driver

mybatis:
  mapper-locations: classpath:mapper/*.xml
  configuration:
    map-underscore-to-camel-case: true

# JWT配置
# 生产环境请使用强随机密钥，至少32字符
jwt:
  secret: "change-me-to-a-long-random-secret-at-least-32-bytes"  # 请修改为强随机字符串
  expire-seconds: 7200

# 阿里云OSS配置（可选）
# 通过环境变量设置敏感信息
aliyun:
  oss:
    endpoint: oss-cn-hangzhou.aliyuncs.com
    bucket: your-bucket-name  # 请修改为你的Bucket名称
    access-key-id: ${ALIYUN_OSS_ACCESS_KEY_ID:}
    access-key-secret: ${ALIYUN_OSS_ACCESS_KEY_SECRET:}
    dir-prefix: work-records/
