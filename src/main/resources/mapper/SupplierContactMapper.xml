<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.zjl.worklog.supplier.mapper.SupplierContactMapper">

    <resultMap id="SupplierContactEntityMap" type="com.zjl.worklog.supplier.entity.SupplierContactEntity">
        <id column="id" property="id"/>
        <result column="supplier_id" property="supplierId"/>
        <result column="contact_name" property="contactName"/>
        <result column="contact_position" property="contactPosition"/>
        <result column="contact_phone" property="contactPhone"/>
        <result column="contact_email" property="contactEmail"/>
        <result column="is_primary" property="isPrimary"/>
        <result column="created_time" property="createdTime"/>
    </resultMap>

    <select id="selectBySupplierId" resultMap="SupplierContactEntityMap">
        SELECT id, supplier_id, contact_name, contact_position, contact_phone, contact_email, is_primary, created_time
        FROM supplier_contact
        WHERE supplier_id = #{supplierId}
        ORDER BY is_primary DESC, id DESC
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO supplier_contact (
            supplier_id, contact_name, contact_position, contact_phone, contact_email, is_primary
        ) VALUES (
            #{supplierId}, #{contactName}, #{contactPosition}, #{contactPhone}, #{contactEmail}, #{isPrimary}
        )
    </insert>

    <delete id="deleteById">
        DELETE FROM supplier_contact
        WHERE id = #{id}
    </delete>

    <delete id="deleteBySupplierId">
        DELETE FROM supplier_contact
        WHERE supplier_id = #{supplierId}
    </delete>

</mapper>
