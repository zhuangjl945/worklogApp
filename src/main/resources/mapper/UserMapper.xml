<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.zjl.worklog.user.mapper.UserMapper">

    <resultMap id="UserEntityMap" type="com.zjl.worklog.user.entity.UserEntity">
        <id column="id" property="id"/>
        <result column="username" property="username"/>
        <result column="password" property="password"/>
        <result column="real_name" property="realName"/>
        <result column="dept_id" property="deptId"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <sql id="UserWhere">
        <where>
            <if test="username != null and username != ''">
                AND username LIKE CONCAT('%', #{username}, '%')
            </if>
            <if test="realName != null and realName != ''">
                AND real_name LIKE CONCAT('%', #{realName}, '%')
            </if>
            <if test="deptId != null">
                AND dept_id = #{deptId}
            </if>
            <if test="deptIds != null and deptIds.size > 0">
                AND dept_id IN
                <foreach collection="deptIds" item="id" open="(" separator="," close=")">
                    #{id}
                </foreach>
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
        </where>
    </sql>

    <select id="selectByUsername" resultMap="UserEntityMap">
        SELECT id, username, password, real_name, dept_id, status, create_time, update_time
        FROM user
        WHERE username = #{username}
        LIMIT 1
    </select>

    <select id="selectById" resultMap="UserEntityMap">
        SELECT id, username, password, real_name, dept_id, status, create_time, update_time
        FROM user
        WHERE id = #{id}
        LIMIT 1
    </select>

    <select id="count" resultType="long">
        SELECT COUNT(1)
        FROM user
        <include refid="UserWhere"/>
    </select>

    <select id="selectPage" resultMap="UserEntityMap">
        SELECT id, username, password, real_name, dept_id, status, create_time, update_time
        FROM user
        <include refid="UserWhere"/>
        ORDER BY id DESC
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO user (username, password, real_name, dept_id, status)
        VALUES (#{username}, #{password}, #{realName}, #{deptId}, #{status})
    </insert>

    <update id="update">
        UPDATE user
        <set>
            <if test="realName != null">real_name = #{realName},</if>
            <if test="deptId != null">dept_id = #{deptId},</if>
            <if test="status != null">status = #{status},</if>
        </set>
        WHERE id = #{id}
    </update>

    <update id="updateStatus">
        UPDATE user
        SET status = #{status}
        WHERE id = #{id}
    </update>

    <update id="updatePassword">
        UPDATE user
        SET password = #{password}
        WHERE id = #{id}
    </update>

</mapper>
