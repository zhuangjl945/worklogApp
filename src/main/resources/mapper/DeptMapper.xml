<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.zjl.worklog.dept.mapper.DeptMapper">

    <resultMap id="DeptEntityMap" type="com.zjl.worklog.dept.entity.DeptEntity">
        <id column="id" property="id"/>
        <result column="dept_code" property="deptCode"/>
        <result column="dept_name" property="deptName"/>
        <result column="parent_id" property="parentId"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <sql id="DeptWhere">
        <where>
            <if test="deptCode != null and deptCode != ''">
                AND dept_code = #{deptCode}
            </if>
            <if test="deptName != null and deptName != ''">
                AND dept_name LIKE CONCAT('%', #{deptName}, '%')
            </if>
            <if test="parentId != null">
                AND parent_id = #{parentId}
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
        </where>
    </sql>

    <select id="count" resultType="long">
        SELECT COUNT(1)
        FROM dept
        <include refid="DeptWhere"/>
    </select>

    <select id="selectPage" resultMap="DeptEntityMap">
        SELECT id, dept_code, dept_name, parent_id, sort_order, status, create_time, update_time
        FROM dept
        <include refid="DeptWhere"/>
        ORDER BY sort_order ASC, id ASC
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <select id="selectAllEnabled" resultMap="DeptEntityMap">
        SELECT id, dept_code, dept_name, parent_id, sort_order, status, create_time, update_time
        FROM dept
        WHERE status = 1
        ORDER BY sort_order ASC, id ASC
    </select>

    <select id="selectById" resultMap="DeptEntityMap">
        SELECT id, dept_code, dept_name, parent_id, sort_order, status, create_time, update_time
        FROM dept
        WHERE id = #{id}
        LIMIT 1
    </select>

    <select id="selectByDeptCode" resultMap="DeptEntityMap">
        SELECT id, dept_code, dept_name, parent_id, sort_order, status, create_time, update_time
        FROM dept
        WHERE dept_code = #{deptCode}
        LIMIT 1
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO dept (dept_code, dept_name, parent_id, sort_order, status)
        VALUES (#{deptCode}, #{deptName}, #{parentId}, #{sortOrder}, #{status})
    </insert>

    <update id="update">
        UPDATE dept
        <set>
            <if test="deptCode != null">dept_code = #{deptCode},</if>
            <if test="deptName != null">dept_name = #{deptName},</if>
            <if test="parentId != null">parent_id = #{parentId},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
            <if test="status != null">status = #{status},</if>
        </set>
        WHERE id = #{id}
    </update>

    <update id="updateStatus">
        UPDATE dept
        SET status = #{status}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM dept
        WHERE id = #{id}
    </delete>

    <select id="countChildren" resultType="long">
        SELECT COUNT(1)
        FROM dept
        WHERE parent_id = #{parentId}
    </select>

    <select id="countUsersInDept" resultType="long">
        SELECT COUNT(1)
        FROM user
        WHERE dept_id = #{deptId}
    </select>

</mapper>
